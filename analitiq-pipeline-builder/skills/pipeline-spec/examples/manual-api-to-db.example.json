{
  "$schema": "https://schemas.analitiq.ai/pipeline/latest.json",
  "alias": "wise_to_postgresql",
  "display_name": "Wise to PostgreSQL",
  "description": "Replicates Wise transfers to a PostgreSQL warehouse on demand.",
  "status": "draft",
  "connections": {
    "source": "wise",
    "destinations": [
      "postgresql"
    ]
  },
  "streams": [],
  "schedule": {
    "type": "manual",
    "timezone": "UTC"
  },
  "engine": {
    "vcpu": 1,
    "memory": 8192
  },
  "runtime": {
    "buffer_size": 5000,
    "batching": {
      "batch_size": 200,
      "max_concurrent_batches": 3
    },
    "logging": {
      "log_level": "INFO",
      "metrics_enabled": true
    },
    "error_handling": {
      "strategy": "dlq",
      "max_retries": 3,
      "retry_delay_seconds": 5
    }
  },
  "tags": ["finance", "warehouse"]
}
