{
  "$schema": "https://schemas.analitiq.ai/pipeline/latest.json",
  "alias": "stripe_to_warehouse_and_lake",
  "display_name": "Stripe to warehouse + lake",
  "description": "Replicates Stripe events to PostgreSQL and S3 daily at 02:00 Berlin time.",
  "status": "draft",
  "connections": {
    "source": "stripe",
    "destinations": [
      "postgresql_warehouse",
      "s3_lake"
    ]
  },
  "streams": [
    "stripe_events_to_warehouse_and_lake"
  ],
  "schedule": {
    "type": "cron",
    "timezone": "Europe/Berlin",
    "cron_expression": "cron(0 2 * * ? *)"
  },
  "engine": {
    "vcpu": 2,
    "memory": 16384
  },
  "runtime": {
    "buffer_size": 10000,
    "batching": {
      "batch_size": 1000,
      "max_concurrent_batches": 5
    },
    "logging": {
      "log_level": "INFO",
      "metrics_enabled": true
    },
    "error_handling": {
      "strategy": "dlq",
      "max_retries": 3,
      "retry_delay_seconds": 10
    }
  },
  "tags": ["billing"]
}
