{
  "$schema": "https://schemas.analitiq.ai/stream/latest.json",
  "alias": "orders_to_warehouse",
  "display_name": "Orders to warehouse",
  "pipeline_id": "mysql_to_postgresql",
  "source": {
    "endpoint_ref": {
      "scope": "connection",
      "connection_id": "mysql_source",
      "alias": "public_orders"
    },
    "selected_columns": ["id", "amount", "updated_at", "status"],
    "filters": [
      {"field": "status", "operator": "eq", "value": "paid"}
    ],
    "replication": {
      "method": "incremental",
      "cursor_field": "updated_at",
      "safety_window_seconds": 300,
      "tie_breaker_fields": ["id"]
    },
    "database_pagination": {
      "type": "offset",
      "page_size": 1000
    }
  },
  "destinations": [
    {
      "endpoint_ref": {
        "scope": "connection",
        "connection_id": "postgresql_warehouse",
        "alias": "warehouse_orders"
      },
      "write": {
        "mode": "upsert",
        "conflict_keys": [["id"]]
      },
      "execution": {
        "batch_size": 1000,
        "max_concurrent_batches": 3
      }
    }
  ],
  "mapping": {
    "assignments": [
      {
        "target": {"path": "id", "arrow_type": "Utf8", "nullable": false},
        "value": {"expression": {"op": "get", "path": "id"}}
      },
      {
        "target": {"path": "amount", "arrow_type": "Decimal128(12, 2)", "native_type": "NUMERIC(12,2)", "nullable": false},
        "value": {"expression": {"op": "get", "path": "amount"}}
      },
      {
        "target": {"path": "updated_at", "arrow_type": "Timestamp(MICROSECOND, UTC)", "nullable": true},
        "value": {"expression": {"op": "get", "path": "updated_at"}}
      }
    ]
  },
  "status": "draft",
  "tags": ["orders", "warehouse"]
}
