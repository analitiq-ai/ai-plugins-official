{
  "$schema": "https://schemas.analitiq.ai/stream/latest.json",
  "alias": "orders_to_warehouse",
  "pipeline_id": "wise_to_postgresql",
  "source": {
    "endpoint_ref": {
      "scope": "connection",
      "connection_id": "mysql_source",
      "alias": "public_orders"
    },
    "replication": {"method": "full_refresh"}
  },
  "destinations": [
    {
      "endpoint_ref": {
        "scope": "connection",
        "connection_id": "postgresql",
        "alias": "warehouse_orders"
      },
      "write": {"mode": "insert"}
    }
  ],
  "mapping": {
    "assignments": [
      {
        "target": {"path": "id", "arrow_type": "Utf8", "nullable": false},
        "value": {
          "expression": {"op": "get", "path": "id"},
          "constant": {"arrow_type": "Utf8", "value": "x"}
        }
      },
      {
        "target": {"path": "id", "arrow_type": "Utf8", "nullable": false},
        "value": {"expression": {"op": "get", "path": "id"}}
      },
      {
        "target": {"path": "status", "arrow_type": "Utf8", "nullable": false},
        "value": {"expression": {"op": "concat", "path": "status"}}
      }
    ]
  }
}
