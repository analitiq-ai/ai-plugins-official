{
  "x-comment": "Reference example, not normative. Models MongoDB document store via SQLAlchemy adapter.",
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "database",
  "alias": "mongodb-example",
  "display_name": "MongoDB Example",
  "description": "Reference connector for MongoDB exposing collections as discoverable resources.",
  "tags": ["example", "database", "mongodb", "document-store"],
  "version": "1.0.0",
  "default_transport": "database",
  "transports": {
    "database": {
      "transport_type": "sqlalchemy",
      "driver": "mongodb",
      "dsn": {
        "kind": "url_template",
        "template": "mongodb://{username}:{password}@{host}:{port}/{database}?authSource={auth_source}",
        "bindings": {
          "username":    { "value": { "ref": "connection.parameters.username" }, "encoding": "url_userinfo" },
          "password":    { "value": { "ref": "secrets.password" }, "encoding": "url_userinfo" },
          "host":        { "value": { "ref": "connection.parameters.host" }, "encoding": "host" },
          "port":        { "value": { "ref": "connection.parameters.port" }, "encoding": "raw" },
          "database":    { "value": { "ref": "connection.parameters.database" }, "encoding": "url_path_segment" },
          "auth_source": { "value": { "ref": "connection.parameters.auth_source" }, "encoding": "url_query_value" }
        }
      }
    }
  },
  "auth": { "type": "db" },
  "connection_contract": {
    "inputs": {
      "host":        { "source": "user", "phase": "pre_auth", "storage": "connection.parameters", "type": "string", "required": true },
      "port":        { "source": "user", "phase": "pre_auth", "storage": "connection.parameters", "type": "integer", "required": true, "default": 27017 },
      "database":    { "source": "user", "phase": "pre_auth", "storage": "connection.parameters", "type": "string", "required": true },
      "auth_source": { "source": "user", "phase": "pre_auth", "storage": "connection.parameters", "type": "string", "required": true, "default": "admin" },
      "username":    { "source": "user", "phase": "auth",     "storage": "connection.parameters", "type": "string", "required": true },
      "password":    { "source": "user", "phase": "auth",     "storage": "secrets",                "type": "string", "required": true, "secret": true }
    }
  },
  "resource_discovery": {
    "strategy": "mongo_collections",
    "transport_ref": "database",
    "implementation": { "type": "builtin" },
    "produces": ["connection.endpoints", "connection.type_map"],
    "triggers": {
      "list_resources": "on_activation",
      "describe_resource": "on_resource_selected"
    }
  },
  "type_maps": {
    "native_to_arrow": {
      "rules": [
        { "method": "exact", "native": "string",   "canonical": "Utf8" },
        { "method": "exact", "native": "int",      "canonical": "Int32" },
        { "method": "exact", "native": "long",     "canonical": "Int64" },
        { "method": "exact", "native": "double",   "canonical": "Float64" },
        { "method": "exact", "native": "decimal",  "canonical": "Decimal128" },
        { "method": "exact", "native": "bool",     "canonical": "Boolean" },
        { "method": "exact", "native": "date",     "canonical": "Timestamp" },
        { "method": "exact", "native": "objectId", "canonical": "Utf8" },
        { "method": "exact", "native": "binData",  "canonical": "Binary" },
        { "method": "exact", "native": "array",    "canonical": "Utf8" },
        { "method": "exact", "native": "object",   "canonical": "Utf8" }
      ]
    }
  }
}
